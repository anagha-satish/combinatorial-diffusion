#!/bin/bash
# Usage:
#   ./run_dpmd.sh [THRESHOLD] [BUDGET] [SEED] [N_EVAL]
#
# Example:
#   ./run_dpmd.sh 300 3 0 10
#
# Runs:
#   python driver_disease_dpmd.py ...
#
# This activates your venv and runs the driver. It does NOT modify system conda.

set -euo pipefail

PROJECT_DIR="/n/netscratch/tambe_lab/Lab/anagha/combinatorial-diffusion"
VENV_DIR="$PROJECT_DIR/dpmd_venv"

# Defaults (match your driver defaults except threshold/budget can be overridden)
THRESHOLD="${1:-300}"
BUDGET="${2:-5}"
SEED="${3:-0}"
N_EVAL="${4:-10}"

cd "$PROJECT_DIR"

echo "Running DPMD (disease):"
echo "  THRESHOLD=$THRESHOLD"
echo "  BUDGET=$BUDGET"
echo "  SEED=$SEED"
echo "  N_EVAL=$N_EVAL"
echo ""

# Load CUDA module (optional)
if command -v module &> /dev/null; then
  module load cuda/12.4.1-fasrc01 2>/dev/null || true
fi

# Activate venv
source "$VENV_DIR/bin/activate"

# Run driver (KEEP EVERYTHING DEFAULT)
python driver_disease_dpmd.py \
  -D HIV \
  -T "$THRESHOLD" \
  -B "$BUDGET" \
  -V "$N_EVAL" \
  -s "$SEED"
